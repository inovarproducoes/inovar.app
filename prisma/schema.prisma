generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Evento {
  id                     String         @id @default(uuid())
  nome                   String
  descricao              String?
  data_inicio            String
  data_fim               String
  horario_inicio         String
  horario_fim            String
  local_nome             String
  endereco_completo      String
  cidade                 String
  estado                 String
  cep                    String?
  link_maps              String?
  capacidade_maxima      Int
  vagas_disponiveis      Int
  valor_total            Float          @default(0)
  valor_entrada          Float          @default(0)
  valor_pendente         Float          @default(0)
  cliente_nome           String?
  cliente_email          String?
  cliente_telefone       String?
  cliente_empresa        String?
  responsavel_nome       String?
  responsavel_cpf        String?
  responsavel_email      String?
  observacoes            String?
  necessidades_especiais String?
  fornecedores           String?
  checklist              String?
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  tipo_evento            String
  status                 String         @default("planejamento")
  evento_alunos          EventoAluno[]
  participantes          Participante[]
  quadro                 Quadro?

  @@index([data_inicio])
  @@index([status])
  @@index([tipo_evento])
  @@map("eventos")
}

model Aluno {
  id                   String        @id @default(uuid())
  matricula            String        @unique
  nome                 String
  idade                Int
  email                String        @unique
  telefone             String
  turma                String
  curso                String
  cidade               String?
  responsavel          String?
  cpf_responsavel      String?
  telefone_responsavel String?
  email_responsavel    String?
  foto_url             String?
  observacoes          String?
  created_by           String?
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt
  status               String        @default("ativo")
  evento_alunos        EventoAluno[]
  parcelas             Parcela[]

  @@index([status])
  @@index([turma])
  @@index([curso])
  @@map("alunos")
}

model Parcela {
  id                    String   @id @default(uuid())
  aluno_id              String
  valor                 Float
  data_vencimento       String
  data_pagamento        String?
  status                String   @default("pendente")
  link_boleto           String?
  link_pix              String?
  identificador_parcela String?  @unique
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  aluno                 Aluno    @relation(fields: [aluno_id], references: [id], onDelete: Cascade)

  @@index([aluno_id])
  @@index([status])
  @@map("parcelas")
}

model EventoAluno {
  id                     String    @id @default(uuid())
  evento_id              String
  aluno_id               String
  funcao                 String?
  mesa                   String?
  acompanhantes          Int       @default(0)
  necessidades_especiais String?
  confirma_presenca      Boolean   @default(false)
  data_confirmacao       DateTime?
  observacoes            String?
  status_participacao    String    @default("pendente")
  aluno                  Aluno     @relation(fields: [aluno_id], references: [id], onDelete: Cascade)
  evento                 Evento    @relation(fields: [evento_id], references: [id], onDelete: Cascade)

  @@unique([evento_id, aluno_id])
  @@map("evento_alunos")
}

model Participante {
  id                 String   @id @default(uuid())
  evento_id          String
  nome               String
  email              String?
  telefone           String?
  observacoes        String?
  created_at         DateTime @default(now())
  status_confirmacao String   @default("pendente")
  tipo_participante  String   @default("comum")
  evento             Evento   @relation(fields: [evento_id], references: [id], onDelete: Cascade)

  @@map("participantes")
}

model FAQ {
  id             String   @id @default(uuid())
  categoria      String
  pergunta       String
  resposta       String
  palavras_chave String   @default("")
  ordem          Int      @default(0)
  ativo          Boolean  @default(true)
  visualizacoes  Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("faqs")
}

model Turma {
  id          String  @id @default(uuid())
  nome        String  @unique
  ano         Int
  ano_letivo  Int?
  curso       String
  coordenador String?
  sala        String?
  capacidade  Int?
  periodo     String?
  status      String  @default("ativa")

  @@map("turmas")
}

model Cliente {
  id           String   @id @default(uuid())
  nome         String
  telefone     String   @unique
  agente_ativo Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  cargo        String?
  email        String?
  empresa      String?
  fonte        String   @default("whatsapp")
  interesse    String?
  lead_score   Int      @default(0)
  observacoes  String?

  @@map("clientes")
}

model Quadro {
  id         String   @id @default(uuid())
  nome       String
  descricao  String?
  evento_id  String?  @unique
  cor_tema   String?  @default("#4f46e5")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  colunas    Coluna[]
  evento     Evento?  @relation(fields: [evento_id], references: [id])
  tarefas    Tarefa[]
  ordens_servico OS[]

  @@map("quadros")
}

model Coluna {
  id         String   @id @default(uuid())
  nome       String
  ordem      Int      @default(0)
  quadro_id  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  quadro     Quadro   @relation(fields: [quadro_id], references: [id], onDelete: Cascade)
  tarefas    Tarefa[]
  ordens_servico OS[]

  @@index([quadro_id])
  @@map("colunas")
}

model Tarefa {
  id               String    @id @default(uuid())
  titulo           String
  descricao        String?
  data_vencimento  DateTime?
  responsavel_nome String?
  etiquetas        String    @default("")
  ordem            Int       @default(0)
  coluna_id        String
  quadro_id        String
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  prioridade       String    @default("media")
  coluna           Coluna    @relation(fields: [coluna_id], references: [id], onDelete: Cascade)
  quadro           Quadro    @relation(fields: [quadro_id], references: [id], onDelete: Cascade)

  @@index([coluna_id])
  @@index([quadro_id])
  @@map("tarefas")
}

model OS {
  id               String   @id @default(uuid())
  numero           Int      @unique @default(autoincrement())
  nome             String
  descricao        String?
  status           String   @default("pendente")
  responsavel_nome String?
  aluno_id         String?
  coluna_id        String?
  quadro_id        String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  coluna           Coluna?  @relation(fields: [coluna_id], references: [id])
  quadro           Quadro?  @relation(fields: [quadro_id], references: [id])

  @@map("ordens_servico")
}

model n8n_chat_histories {
  id         Int    @id @default(autoincrement())
  session_id String @db.VarChar(255)
  message    Json
}
