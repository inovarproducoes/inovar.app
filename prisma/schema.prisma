generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Aluno {
  id                   String        @id @default(uuid())
  matricula            String?       @unique
  nome                 String
  cpf                  String?       @unique
  idade                Int?
  email                String?       @unique
  telefone             String?
  turma                String?
  curso                String?
  cidade               String?
  responsavel          String?
  cpf_responsavel      String?
  telefone_responsavel String?
  email_responsavel    String?
  foto_url             String?
  observacoes          String?
  created_by           String?
  created_at           DateTime      @default(now())
  updated_at           DateTime      @default(now()) @updatedAt
  status               String        @default("ativo")
  instituicao          String?
  projeto              String?
  financeiro_parcelas  Json?

  @@index([status])
  @@index([turma])
  @@index([curso])
  @@index([cpf])
  @@index([instituicao])
  @@index([projeto])
  @@map("alunos")
}



model Turma {
  id          String  @id @default(uuid())
  nome        String  @unique
  ano         Int
  ano_letivo  Int?
  curso       String
  coordenador String?
  sala        String?
  capacidade  Int?
  periodo     String?
  status      String  @default("ativa")

  @@map("turmas")
}

model Cliente {
  id           String   @id @default(uuid())
  nome         String
  telefone     String   @unique
  agente_ativo Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  cargo        String?
  email        String?
  empresa      String?
  fonte        String   @default("whatsapp")
  interesse    String?
  lead_score   Int      @default(0)
  observacoes  String?

  @@map("clientes")
}

model Quadro {
  id             String   @id @default(uuid())
  nome           String
  descricao      String?
  ativo          Boolean  @default(false)
  arquivado      Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt
  colunas        Coluna[]
  ordens_servico OS[]
  tarefas        Tarefa[]

  @@map("quadros")
}

model Coluna {
  id             String   @id @default(uuid())
  nome           String
  ordem          Int      @default(0)
  quadro_id      String
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt
  quadro         Quadro   @relation(fields: [quadro_id], references: [id], onDelete: Cascade)
  ordens_servico OS[]
  tarefas        Tarefa[]

  @@index([quadro_id])
  @@map("colunas")
}

model Tarefa {
  id               String    @id @default(uuid())
  titulo           String
  descricao        String?
  data_vencimento  DateTime?
  responsavel_nome String?
  etiquetas        String    @default("")
  ordem            Int       @default(0)
  coluna_id        String
  quadro_id        String
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt
  prioridade       String    @default("media")
  instituicao      String?
  projeto_nome     String?
  arquivado        Boolean   @default(false)
  coluna           Coluna    @relation(fields: [coluna_id], references: [id], onDelete: Cascade)
  quadro           Quadro    @relation(fields: [quadro_id], references: [id], onDelete: Cascade)

  @@index([coluna_id])
  @@index([quadro_id])
  @@index([arquivado])
  @@map("tarefas")
}

model OS {
  id               String   @id @default(uuid())
  numero           String?
  nome             String
  descricao        String?
  status           String   @default("pendente")
  responsavel_nome String?
  aluno_id         String?
  aluno_nome       String?
  aluno_cpf        String?
  projeto_nome     String?
  instituicao      String?
  arquivado        Boolean  @default(false)
  ordem            Int      @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt
  coluna_id        String?
  quadro_id        String?
  coluna           Coluna?  @relation(fields: [coluna_id], references: [id])
  quadro           Quadro?  @relation(fields: [quadro_id], references: [id])

  @@unique([numero])
  @@map("ordens_servico")
}

model Usuario {
  id         String   @id @default(uuid())
  nome       String
  email      String   @unique
  senha_hash String
  role       String   @default("user")
  ativo      Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("usuarios")
}

model n8n_chat_histories {
  id         Int    @id @default(autoincrement())
  session_id String @db.VarChar(255)
  message    Json
}
